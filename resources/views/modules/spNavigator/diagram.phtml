<?php

use Fisharebest\Webtrees\I18N;
use Fisharebest\Webtrees\View;

/**
 * @var object|null $individual
 * @var string      $cardHtml
 * @var string      $initScript
 * @var string      $module
 * @var string      $pageHeading
 * @var bool        $showForm
 * @var object      $tree
 * @var bool|null   $inlineScript
 */

$inlineScript = $inlineScript ?? false;
?>

<div class="wtp-plugin-root<?= $inlineScript ? ' sp-embedded-view' : ' sp-page-view' ?>">
<div class="sp-full-space">
    <?= $cardHtml ?>
</div>

<?php if ($individual !== null || $initScript !== '') : ?>
    <?php if ($inlineScript) : ?>
        <script>
            <?= $initScript ?>
            if (typeof spNavController !== 'undefined') {
                window.requestAnimationFrame(function () {
                    if (spNavController && spNavController.measureAndRender) {
                        spNavController.measureAndRender();
                        if (spNavController._setCurrentXref) {
                            spNavController._setCurrentXref(spNavController.baseXref || null);
                        }
                        if (spNavController.startExpanded) {
                            spNavController.focusOrigin();
                        }
                    }
                });

                document.addEventListener('shown.bs.tab', function () {
                    window.requestAnimationFrame(function () {
                        if (spNavController && spNavController.measureAndRender) {
                            spNavController.measureAndRender();
                            if (spNavController._setCurrentXref) {
                                spNavController._setCurrentXref(spNavController.baseXref || null);
                            }
                            if (spNavController.startExpanded) {
                                spNavController.focusOrigin();
                            }
                        }
                    });
                });
            }
        </script>
    <?php else : ?>
        <?php View::push('javascript') ?>
        <script>
            <?= $initScript ?>
            if (typeof spNavController !== 'undefined') {
                window.requestAnimationFrame(function () {
                    if (spNavController && spNavController.measureAndRender) {
                        spNavController.measureAndRender();
                    }
                });
            }
        </script>
        <?php View::endpush() ?>
    <?php endif; ?>
<?php endif; ?>

</div>

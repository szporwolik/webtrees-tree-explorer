<?php

use Fisharebest\Webtrees\I18N;
use Fisharebest\Webtrees\View;

/**
 * @var object|null $individual
 * @var string      $cardHtml
 * @var string      $initScript
 * @var string      $module
 * @var string      $pageHeading
 * @var bool        $showForm
 * @var object      $tree
 */

?>

<div class="wtp-plugin-root">

<?php if ($showForm) : ?>
<h3 class="wt-page-title sp-page-heading">
    <?= $pageHeading ?>
</h3>

<form method="post" class="wt-page-options wt-page-options-compact-chart d-print-none">
    <?= csrf_field() ?>

    <div class="row form-group">
        <label class="col-sm-2 col-form-label wt-page-options-label" for="xref">
            <?= I18N::translate('Individual') ?>
        </label>
        <div class="col-sm-10 wt-page-options-value">
            <?= view('components/select-individual', [
                'name'       => 'xref',
                'individual' => $individual,
                'tree'       => $tree,
                'required'   => true,
            ]) ?>
        </div>
    </div>

    <div class="row form-group">
        <div class="col-sm-2 wt-page-options-label"></div>
        <div class="col-sm-2 wt-page-options-value">
            <input class="btn btn-primary" type="submit" value="<?= I18N::translate('view') ?>">
        </div>
    </div>
</form>

<?php if ($individual === null) : ?>
    <div class="alert alert-info">
        <?= I18N::translate('Select an individual to display their family tree.') ?>
    </div>
<?php endif ?>
<?php endif ?>

<?php if ($individual !== null) : ?>
<div class="<?= $showForm ? '' : 'sp-full-space' ?>">
    <?= $cardHtml ?>
</div>

    <?php View::push('javascript') ?>
    <script>
        <?= $initScript ?>
    </script>
    <?php View::endpush() ?>
<?php endif ?>

</div>
